{
  "name": "n8n-nodes-supabase",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Supabase providing database operations, authentication, storage, edge functions, realtime subscriptions, and management APIs with 10 resources and 70+ operations.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-supabase.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-supabase#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-supabase/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "supabase",
    "postgresql",
    "database",
    "authentication",
    "storage",
    "realtime",
    "edge-functions",
    "backend-as-a-service",
    "baas",
    "firebase-alternative",
    "postgrest",
    "automation",
    "workflow"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SupabaseApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Supabase/Supabase.node.js",
      "dist/nodes/Supabase/SupabaseTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}